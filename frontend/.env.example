BACKEND_HOST=http://127.0.0.1:8000

# Must match ANALYTICS_INGEST_TOKEN in the backend environment. Keep this server-only.
ANALYTICS_INGEST_TOKEN=

# Sentry browser and SvelteKit monitoring. A Sentry DSN is safe to expose publicly.
PUBLIC_SENTRY_DSN=
PUBLIC_SENTRY_ENVIRONMENT=local
PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# Optional server-side override. Defaults to PUBLIC_SENTRY_TRACES_SAMPLE_RATE.
SENTRY_TRACES_SAMPLE_RATE=0.1

# Optional build-only values for release creation and source-map uploads.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
